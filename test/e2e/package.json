{
  "name": "repsaga-e2e",
  "version": "1.0.0",
  "description": "Playwright e2e tests for RepSaga Flutter web app",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:full": "playwright test --grep-invert @smoke",
    "test:ui": "playwright test --ui",
    "test:smoke:ui": "playwright test --grep @smoke --ui",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "dotenv": "^16.4.5"
  }
}
